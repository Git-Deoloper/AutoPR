# Configuration file for LocalClaw
# Copy to .env and customize for your setup

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama2

# Web UI Configuration
WEB_HOST=127.0.0.1
WEB_PORT=8000
WEB_DEBUG=False
WEB_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
WEB_ALLOW_CREDENTIALS=False

# Code Reading Configuration
MAX_FILE_SIZE=1048576
IGNORE_DIRS=__pycache__,.git,.venv,node_modules,build,dist
IGNORE_FILES=.DS_Store,.env,package-lock.json

# Logging
LOG_LEVEL=INFO
